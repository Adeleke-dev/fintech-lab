    {
      "name": "POST /payments/intent - idempotency",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = pm.response.json();\r",
              "\r",
              "// Try to get payment id (adjust if your API uses different key)\r",
              "let paymentId = responseJson.id || responseJson.paymentId || null;\r",
              "\r",
              "// Get stored value from previous run\r",
              "let previousId = pm.environment.get(\"last_payment_id\");\r",
              "\r",
              "// If this is the first request, store the id\r",
              "if (!previousId) {\r",
              "    pm.environment.set(\"last_payment_id\", paymentId);\r",
              "    pm.test(\"Stored first payment ID\", function () {\r",
              "        pm.expect(paymentId).to.not.be.null;\r",
              "    });\r",
              "} else {\r",
              "    // Second request → compare\r",
              "    pm.test(\"Idempotency check - same ID returned\", function () {\r",
              "        pm.expect(paymentId).to.eql(previousId);\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"amount\": {{amount}},\r\n  \"currency\": \"{{currency}}\",\r\n  \"email\": \"{{email}}\",\r\n  \"reference\": \"{{reference}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
