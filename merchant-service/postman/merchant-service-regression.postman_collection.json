          "name": "POST /payments/intent - invalid",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code matches expected negative status\", function () {\r",
                  "    pm.expect(pm.response.code).to.eql(Number(pm.iterationData.get(\"expected_status\")));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is not a success\", function () {\r",
                  "    pm.expect(pm.response.code).to.not.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is acceptable\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
